{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "chess-bench/benchmark-run.v1",
  "title": "BenchmarkRunV1",
  "type": "object",
  "required": [
    "runId",
    "createdAt",
    "datasetId",
    "modelId",
    "provider",
    "promptMode",
    "promptVersion",
    "summary",
    "attempts"
  ],
  "properties": {
    "runId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "datasetId": { "type": "string" },
    "modelId": { "type": "string" },
    "provider": { "type": "string" },
    "promptMode": { "type": "string", "enum": ["benchmark", "showcase"] },
    "promptVersion": { "type": "string" },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "parsed",
        "correctStrict",
        "accuracyStrict",
        "totalPromptTokens",
        "totalCompletionTokens",
        "totalReasoningTokens",
        "totalCost",
        "averageLatencyMs"
      ],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "parsed": { "type": "integer", "minimum": 0 },
        "correctStrict": { "type": "integer", "minimum": 0 },
        "accuracyStrict": { "type": "number", "minimum": 0, "maximum": 1 },
        "totalPromptTokens": { "type": "integer", "minimum": 0 },
        "totalCompletionTokens": { "type": "integer", "minimum": 0 },
        "totalReasoningTokens": { "type": "integer", "minimum": 0 },
        "totalCost": { "type": "number", "minimum": 0 },
        "averageLatencyMs": { "type": "number", "minimum": 0 }
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "index",
          "puzzleId",
          "track",
          "ratingBucket",
          "expectedLine",
          "rawOutput",
          "parsedLine",
          "parseStatus",
          "formatValid",
          "correctStrict",
          "latencyMs",
          "usage"
        ],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "puzzleId": { "type": "string" },
          "track": { "type": "string" },
          "ratingBucket": { "type": "string" },
          "sourceFen": { "type": "string" },
          "initialMove": { "type": "string" },
          "currentFen": { "type": "string" },
          "sideToMove": { "type": "string", "enum": ["White", "Black"] },
          "expectedLine": { "type": "string" },
          "rawOutput": { "type": "string" },
          "parsedLine": { "type": ["string", "null"] },
          "parseStatus": { "type": "string" },
          "formatValid": { "type": "boolean" },
          "correctStrict": { "type": "boolean" },
          "thinkingText": { "type": ["string", "null"] },
          "latencyMs": { "type": "number", "minimum": 0 },
          "usage": {
            "type": "object",
            "required": [
              "promptTokens",
              "completionTokens",
              "reasoningTokens",
              "totalTokens",
              "cost"
            ],
            "properties": {
              "promptTokens": { "type": "integer", "minimum": 0 },
              "completionTokens": { "type": "integer", "minimum": 0 },
              "reasoningTokens": { "type": "integer", "minimum": 0 },
              "totalTokens": { "type": "integer", "minimum": 0 },
              "cost": { "type": "number", "minimum": 0 }
            }
          },
          "responseError": {
            "type": ["object", "null"]
          }
        }
      }
    }
  }
}
